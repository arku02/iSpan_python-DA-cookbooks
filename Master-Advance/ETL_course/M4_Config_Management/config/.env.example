# ===================================================================
# .env.example —— 機密設定範本
# ===================================================================
#
# 使用方式：
#   1. 複製這支檔案為 .env：
#        cp .env.example .env
#   2. 在 .env 填入真實值
#   3. .env 已被 .gitignore（root 第 123 行）忽略，不會上 commit
#   4. 程式用 python-dotenv 載入：
#        from dotenv import load_dotenv
#        load_dotenv()                    # 自動找 .env
#        import os
#        db = os.getenv("DATABASE_URL")
#
# 規則：
#   - KEY=value   中間不要空格
#   - 值有空格時用雙引號包："hello world"
#   - 註解用 #
#   - 機密（密碼、API key、token）一律放這裡，不要寫死在 code
# ===================================================================


# --- 資料庫連線字串 ---
# 格式：postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://etl_user:CHANGE_ME_TO_REAL_PASSWORD@localhost:5432/etl_db

# --- 應用程式密鑰（JWT 簽章、session 加密用）---
# 產生方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_32_BYTES_STRING

# --- 除錯模式 ---
# True  → 顯示 stack trace、印 SQL（開發用）
# False → 正式環境必用，避免洩漏內部結構
DEBUG=False


# --- 第三方 API 金鑰（可選範例）---
# OPENAI_API_KEY=sk-...
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...


# --- 環境標記 ---
# 用來在程式裡區分 dev / staging / prod，走不同 config 分支
ENV=development
